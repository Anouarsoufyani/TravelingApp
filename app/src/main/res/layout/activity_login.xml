<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center"
    android:background="@color/background_color">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Traveling"
        android:fontFamily="serif"

        android:textColor="@color/navy"
        android:textSize="42sp"
        android:textStyle="bold"
        android:layout_marginBottom="48dp" />

    <EditText
        android:id="@+id/et_username"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:paddingHorizontal="16dp"
        android:background="@drawable/bg_input"

        android:hint="Login"
        android:textColor="@color/ink"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/et_password"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:paddingHorizontal="16dp"
        android:background="@drawable/bg_input"

        android:hint="Mot de passe"
        android:inputType="textPassword"
        android:textColor="@color/ink"
        android:layout_marginBottom="32dp"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_login"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Se connecter"
        android:textColor="@color/default_white"
        android:background="@drawable/bg_pill_solid"

        android:textAllCaps="false"
        android:textSize="16sp"
        android:layout_marginBottom="16dp"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_register"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Pas encore de compte ?"
        android:background="@drawable/bg_pill_outline"
        android:textColor="@color/ink"

        android:textAllCaps="false"
        android:textSize="16sp"
        android:layout_marginBottom="24dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_strong"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btn_anonymous"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Continuer en mode Anonyme"

        style="?android:attr/borderlessButtonStyle"
        android:textAllCaps="false"
        android:textColor="@color/ink_muted"/>
</LinearLayout>
