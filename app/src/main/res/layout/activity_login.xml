<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_travel">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_login_overlay" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="@dimen/space_xl"
        android:paddingEnd="@dimen/space_xl">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-condensed"
            android:letterSpacing="0"
            android:text="@string/app_logo"
            android:textColor="@color/default_white"
            android:textSize="@dimen/login_logo_size"
            android:textStyle="bold" />

        <TextView
            style="@style/TextAppearance.Travelshare.BodyMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:layout_marginBottom="@dimen/space_2xl"
            android:text="@string/login_tagline"
            android:textColor="@color/ink_muted" />

        <EditText
            android:id="@+id/et_email"
            android:layout_width="match_parent"
            android:layout_height="@dimen/search_height"
            android:layout_marginBottom="@dimen/space_sm"
            android:background="@drawable/bg_input"
            android:hint="@string/hint_email"
            android:inputType="textEmailAddress"
            android:minHeight="@dimen/touch_target"
            android:paddingStart="@dimen/space_md"
            android:paddingEnd="@dimen/space_md"
            android:textColor="@color/default_white"
            android:textColorHint="@color/ink_faint" />

        <EditText
            android:id="@+id/et_password"
            android:layout_width="match_parent"
            android:layout_height="@dimen/search_height"
            android:layout_marginBottom="@dimen/space_xl"
            android:background="@drawable/bg_input"
            android:hint="@string/hint_password"
            android:inputType="textPassword"
            android:minHeight="@dimen/touch_target"
            android:paddingStart="@dimen/space_md"
            android:paddingEnd="@dimen/space_md"
            android:textColor="@color/default_white"
            android:textColorHint="@color/ink_faint" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_login"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginBottom="@dimen/space_sm"
            android:text="@string/sign_in_register"
            android:textAllCaps="false"
            android:textColor="@color/default_white"
            app:backgroundTint="@color/coral"
            app:cornerRadius="@dimen/radius_md" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_anonymous"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginBottom="@dimen/space_sm"
            android:text="@string/explore_anonymously"
            android:textAllCaps="false"
            android:textColor="@color/default_white"
            app:cornerRadius="@dimen/radius_md"
            app:strokeColor="@color/default_white"
            app:strokeWidth="@dimen/stroke_hairline" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_register"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/touch_target"
            android:text="@string/create_account"
            android:textAllCaps="false"
            android:textColor="@color/sand" />
    </LinearLayout>
</FrameLayout>
