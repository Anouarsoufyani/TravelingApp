<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_xl"
            android:paddingTop="@dimen/space_xl"
            android:paddingEnd="@dimen/space_xl"
            android:paddingBottom="@dimen/space_md">

            <!-- Title Section -->
            <TextView
                style="@style/TextAppearance.Travelshare.HeadlineLarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/explorer_title"
                android:textColor="@color/default_white"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                style="@style/TextAppearance.Travelshare.BodyMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                android:text="Trouvez votre prochaine destination"
                android:textColor="@color/sheet_muted" />

            <!-- Search Bar integrated with Random Button -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="@dimen/search_height"
                android:layout_marginTop="@dimen/space_lg"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/space_md"
                    android:paddingEnd="@dimen/space_xs">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/search_hint"
                        android:src="@drawable/ic_ms_search"
                        app:tint="@color/sheet_muted" />

                    <EditText
                        android:id="@+id/et_search_query"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="@string/search_hint"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:paddingStart="@dimen/space_sm"
                        android:paddingEnd="@dimen/space_sm"
                        android:textColor="@color/default_white"
                        android:textColorHint="@color/ink_faint"
                        android:textSize="16sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_random_feed"
                        android:layout_width="@dimen/touch_target"
                        android:layout_height="@dimen/touch_target"
                        android:layout_marginEnd="4dp"
                        android:contentDescription="Random Feed"
                        android:insetBottom="0dp"
                        android:insetTop="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="0dp"
                        android:text="✦"
                        android:textColor="@color/coral"
                        android:textSize="20sp"
                        app:backgroundTint="@color/coral_soft"
                        app:cornerRadius="@dimen/radius_pill" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_voice_search"
                        android:layout_width="@dimen/touch_target"
                        android:layout_height="@dimen/touch_target"
                        android:contentDescription="@string/voice_search"
                        android:insetBottom="0dp"
                        android:insetTop="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="0dp"
                        android:text="🎙"
                        android:textColor="@color/default_white"
                        android:textSize="20sp"
                        app:backgroundTint="@color/coral"
                        app:cornerRadius="@dimen/radius_pill" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="false"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/space_md">

            <!-- Chips / Quick Filters -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingStart="@dimen/space_xl"
                android:paddingEnd="@dimen/space_xl"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chip_all"
                        style="@style/TextAppearance.Travelshare.LabelSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="@dimen/space_xs"
                        android:background="@drawable/bg_pill_solid"
                        android:gravity="center"
                        android:paddingStart="@dimen/space_md"
                        android:paddingEnd="@dimen/space_md"
                        android:text="@string/chip_all"
                        android:textColor="@color/default_white" />

                    <TextView
                        android:id="@+id/chip_nature"
                        style="@style/TextAppearance.Travelshare.LabelSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="@dimen/space_xs"
                        android:background="@drawable/bg_collection_card"
                        android:gravity="center"
                        android:paddingStart="@dimen/space_md"
                        android:paddingEnd="@dimen/space_md"
                        android:text="🌿 Nature" />

                    <TextView
                        android:id="@+id/chip_culture"
                        style="@style/TextAppearance.Travelshare.LabelSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="@dimen/space_xs"
                        android:background="@drawable/bg_collection_card"
                        android:gravity="center"
                        android:paddingStart="@dimen/space_md"
                        android:paddingEnd="@dimen/space_md"
                        android:text="🏛 Culture" />

                    <TextView
                        android:id="@+id/chip_magasin"
                        style="@style/TextAppearance.Travelshare.LabelSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="@dimen/space_xs"
                        android:background="@drawable/bg_collection_card"
                        android:gravity="center"
                        android:paddingStart="@dimen/space_md"
                        android:paddingEnd="@dimen/space_md"
                        android:text="🍽 Food" />

                    <TextView
                        android:id="@+id/chip_urbain"
                        style="@style/TextAppearance.Travelshare.LabelSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="@dimen/space_xs"
                        android:background="@drawable/bg_collection_card"
                        android:gravity="center"
                        android:paddingStart="@dimen/space_md"
                        android:paddingEnd="@dimen/space_md"
                        android:text="🎭 Leisure" />

                    <TextView
                        android:id="@+id/chip_nearby"
                        style="@style/TextAppearance.Travelshare.LabelSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="@dimen/space_xs"
                        android:background="@drawable/bg_collection_card"
                        android:gravity="center"
                        android:paddingStart="@dimen/space_md"
                        android:paddingEnd="@dimen/space_md"
                        android:text="📍 Nearby" />

                    <TextView
                        android:id="@+id/chip_likes"
                        style="@style/TextAppearance.Travelshare.LabelSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_collection_card"
                        android:gravity="center"
                        android:paddingStart="@dimen/space_md"
                        android:paddingEnd="@dimen/space_md"
                        android:text="@string/chip_likes" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Quick Actions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_xl"
                android:layout_marginTop="@dimen/space_md"
                android:layout_marginEnd="@dimen/space_xl"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_explorer_travelpath"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="start|center_vertical"
                    android:text="@string/plan_trip"
                    android:textAllCaps="false"
                    android:textColor="@color/coral"
                    android:textSize="16sp"
                    app:icon="@drawable/ic_ms_explore"
                    app:iconTint="@color/coral" />

                <TextView
                    android:id="@+id/btn_toggle_view"
                    style="@style/TextAppearance.Travelshare.LabelSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_pill_outline"
                    android:gravity="center"
                    android:paddingStart="@dimen/space_md"
                    android:paddingEnd="@dimen/space_md"
                    android:text="@string/toggle_grid"
                    android:textColor="@color/sand" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.facebook.shimmer.ShimmerFrameLayout
        android:id="@+id/shimmer_feed"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/space_md"
        android:paddingEnd="@dimen/space_md"
        android:visibility="gone"
        app:shimmer_auto_start="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/photo_card_height"
                android:layout_marginBottom="@dimen/space_sm"
                android:background="@drawable/bg_card_md" />

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/photo_card_height"
                android:background="@drawable/bg_card_md" />
        </LinearLayout>
    </com.facebook.shimmer.ShimmerFrameLayout>

    <FrameLayout
        android:id="@+id/empty_feed_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/space_xl">

            <ImageView
                android:layout_width="@dimen/empty_illustration_size"
                android:layout_height="@dimen/empty_illustration_size"
                android:contentDescription="@string/empty_headline"
                android:src="@drawable/bg_empty_illustration" />

            <TextView
                style="@style/TextAppearance.Travelshare.TitleMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:gravity="center"
                android:text="@string/empty_headline" />

            <TextView
                style="@style/TextAppearance.Travelshare.BodyMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                android:gravity="center"
                android:text="@string/empty_subtext" />

            <com.google.android.material.button.MaterialButton
                android:layout_width="wrap_content"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/space_md"
                android:text="@string/retry"
                android:textAllCaps="false"
                android:textColor="@color/default_white"
                app:backgroundTint="@color/coral"
                app:cornerRadius="@dimen/radius_md" />
        </LinearLayout>
    </FrameLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view_photos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="@dimen/bottom_nav_height" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
</LinearLayout>
