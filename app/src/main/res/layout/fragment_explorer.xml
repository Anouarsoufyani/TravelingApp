<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_color"
    android:padding="16dp">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="travel·share"
        android:textSize="24sp"
        android:textColor="@color/navy"
        android:layout_marginBottom="12dp" />

    <!-- Bouton TravelPath -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_explorer_travelpath"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="🗺 Planifier un voyage — TravelPath"
        android:textColor="@color/default_white"
        android:background="@drawable/bg_pill_solid"
        android:textAllCaps="false"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <!-- Barre de recherche + bouton micro -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <EditText
            android:id="@+id/et_search_query"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:hint="Rechercher une destination..."
            android:paddingHorizontal="16dp"
            android:background="@drawable/bg_pill_outline"
            android:textColor="@color/ink"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="8dp"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:layout_marginEnd="8dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_voice_search"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:text="🎤"
            android:textSize="18sp"
            android:background="@drawable/bg_pill_solid"
            android:textColor="@color/default_white"
            android:padding="0dp" />
    </LinearLayout>

    <!-- Filtres avancés : auteur + période -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <EditText
            android:id="@+id/et_filter_author"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="44dp"
            android:hint="Par auteur"
            android:paddingHorizontal="12dp"
            android:background="@drawable/bg_input"
            android:textColor="@color/ink"
            android:textSize="13sp"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/et_filter_date_start"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="44dp"
            android:hint="Depuis (AAAA-MM-JJ)"
            android:paddingHorizontal="12dp"
            android:background="@drawable/bg_input"
            android:textColor="@color/ink"
            android:textSize="12sp"
            android:inputType="text"
            android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/et_filter_date_end"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="44dp"
            android:hint="Jusqu'à"
            android:paddingHorizontal="12dp"
            android:background="@drawable/bg_input"
            android:textColor="@color/ink"
            android:textSize="12sp"
            android:inputType="text"/>
    </LinearLayout>

    <!-- Chips de catégorie — rangée 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/chip_all"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="Tout"
            android:textSize="12sp"
            android:background="@drawable/bg_pill_solid"
            android:textColor="@color/default_white"
            android:layout_marginEnd="6dp"/>

        <TextView
            android:id="@+id/chip_nature"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="Nature"
            android:textSize="12sp"
            android:background="@drawable/bg_pill_outline"
            android:textColor="@color/ink_muted"
            android:layout_marginEnd="6dp"/>

        <TextView
            android:id="@+id/chip_urbain"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="Urbain"
            android:textSize="12sp"
            android:background="@drawable/bg_pill_outline"
            android:textColor="@color/ink_muted"
            android:layout_marginEnd="6dp"/>

        <TextView
            android:id="@+id/chip_culture"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="Culture"
            android:textSize="12sp"
            android:background="@drawable/bg_pill_outline"
            android:textColor="@color/ink_muted"/>

    </LinearLayout>

    <!-- Chips de catégorie — rangée 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/chip_magasin"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="Magasin"
            android:textSize="12sp"
            android:background="@drawable/bg_pill_outline"
            android:textColor="@color/ink_muted"
            android:layout_marginEnd="6dp"/>

        <TextView
            android:id="@+id/chip_nearby"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="📍 Autour"
            android:textSize="12sp"
            android:background="@drawable/bg_pill_outline"
            android:textColor="@color/ink_muted"
            android:layout_marginEnd="6dp"/>

        <TextView
            android:id="@+id/chip_likes"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="❤️ Likes"
            android:textSize="12sp"
            android:background="@drawable/bg_pill_outline"
            android:textColor="@color/ink_muted"
            android:layout_marginEnd="6dp"/>

        <TextView
            android:id="@+id/btn_random_feed"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="🎲 Aléat."
            android:textSize="12sp"
            android:background="@drawable/bg_pill_outline"
            android:textColor="@color/ink_muted"/>

    </LinearLayout>

    <!-- Toggle liste / grille -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/btn_toggle_view"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:paddingHorizontal="14dp"
            android:gravity="center"
            android:text="☰ Liste"
            android:textSize="12sp"
            android:background="@drawable/bg_pill_outline"
            android:textColor="@color/ink_muted"/>
    </LinearLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view_photos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="80dp"/>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>
