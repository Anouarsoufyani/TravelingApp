<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color">

    <org.osmdroid.views.MapView
        android:id="@+id/map_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="@dimen/space_xl"
        android:paddingHorizontal="@dimen/space_md">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/overlay_photo_bottom"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardElevation="4dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/space_md">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/TextAppearance.Travelshare.TitleMedium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Carte des souvenirs"
                        android:textColor="@color/default_white" />

                    <TextView
                        style="@style/TextAppearance.Travelshare.LabelSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                    android:text="Touchez un repère pour ouvrir la publication"
                        android:textColor="@color/ink_faint" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_map_count"
                    style="@style/StatValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="14sp"
                    android:textColor="@color/sand" />

                <TextView
                    style="@style/StatLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="PUBLICATIONS"
                    android:textSize="10sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="@dimen/space_md"
        android:layout_marginEnd="@dimen/space_md"
        android:layout_marginBottom="92dp"
        app:cardBackgroundColor="@color/overlay_photo_bottom"
        app:cardCornerRadius="@dimen/radius_lg"
        app:cardElevation="@dimen/elevation_card"
        app:strokeColor="@color/border_light"
        app:strokeWidth="@dimen/stroke_hairline">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/space_md"
            android:paddingEnd="@dimen/space_sm">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/TextAppearance.Travelshare.TitleMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Créer un itinéraire"
                    android:textColor="@color/default_white" />

                <TextView
                    style="@style/TextAppearance.Travelshare.LabelSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="TravelPath depuis la carte"
                    android:textColor="@color/ink_faint" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/fab_map_plan"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/touch_target"
                android:minWidth="132dp"
                android:text="Planifier"
                android:textAllCaps="false"
                android:textColor="@color/default_white"
                app:backgroundTint="@color/coral"
                app:cornerRadius="@dimen/radius_md"
                app:icon="@drawable/ic_ms_explore"
                app:iconGravity="textStart"
                app:iconTint="@color/default_white" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
