<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="28dp"
    android:gravity="center"
    android:background="@color/background_color">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Créer un compte"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/ink"
        android:layout_marginBottom="40dp"/>

    <EditText
        android:id="@+id/et_reg_username"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Nom d'utilisateur"
        android:inputType="textPersonName"
        android:paddingHorizontal="16dp"
        android:background="@drawable/bg_input"
        android:textColor="@color/ink"
        android:textColorHint="@color/ink_faint"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/et_reg_password"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Mot de passe"
        android:inputType="textPassword"
        android:paddingHorizontal="16dp"
        android:background="@drawable/bg_input"
        android:textColor="@color/ink"
        android:textColorHint="@color/ink_faint"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btn_do_register"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="S'inscrire"
        android:background="@drawable/bg_pill_solid"
        android:textColor="@color/default_white"
        android:textAllCaps="false"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btn_back_to_login"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Retour à la connexion"
        style="?android:attr/borderlessButtonStyle"
        android:textAllCaps="false"
        android:textColor="@color/ink_muted"/>
</LinearLayout>
