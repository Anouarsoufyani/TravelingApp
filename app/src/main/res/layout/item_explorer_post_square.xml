<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/space_lg"
    android:layout_marginEnd="@dimen/space_lg"
    android:layout_marginBottom="@dimen/space_lg"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/navy_light"
    app:cardCornerRadius="@dimen/radius_md"
    app:cardElevation="@dimen/elevation_card"
    app:strokeWidth="@dimen/stroke_none">

    <com.example.travelshare.ui.theme.views.SquareFrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <View
            android:id="@+id/explorer_post_placeholder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_photo_placeholder" />

        <ImageView
            android:id="@+id/iv_explorer_post"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/photo_content_description"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <View
            android:layout_width="match_parent"
            android:layout_height="164dp"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_photo_overlay_gradient" />

        <TextView
            android:id="@+id/tv_explorer_multi_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="@dimen/space_sm"
            android:background="@drawable/bg_pill_solid"
            android:backgroundTint="@color/overlay_soft"
            android:paddingHorizontal="@dimen/space_xs"
            android:paddingVertical="@dimen/space_xxs"
            android:textColor="@color/default_white"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:gravity="bottom"
            android:orientation="horizontal"
            android:padding="@dimen/space_md">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_explorer_location"
                    style="@style/TextAppearance.Travelshare.LabelSmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/sand"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_explorer_title"
                    style="@style/TextAppearance.Travelshare.HeadlineLarge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xxs"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/default_white"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_explorer_author"
                    style="@style/TextAppearance.Travelshare.BodyMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xxs"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/ink_muted" />

                <TextView
                    android:id="@+id/tv_explorer_tags"
                    style="@style/TextAppearance.Travelshare.LabelSmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xxs"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/ink_faint" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_sm"
                android:gravity="center"
                android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_explorer_like"
                    android:layout_width="@dimen/touch_target"
                    android:layout_height="@dimen/touch_target"
                    android:contentDescription="@string/like_icon_description"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    app:backgroundTint="@color/overlay_soft"
                    app:cornerRadius="@dimen/radius_pill"
                    app:icon="@drawable/ic_ms_heart"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconSize="22dp"
                    app:iconTint="@color/default_white" />

                <TextView
                    android:id="@+id/tv_explorer_likes"
                    style="@style/TextAppearance.Travelshare.LabelSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xxs"
                    android:textColor="@color/default_white"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_explorer_share"
                    android:layout_width="@dimen/touch_target"
                    android:layout_height="@dimen/touch_target"
                    android:layout_marginTop="@dimen/space_sm"
                    android:contentDescription="Partager"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    app:backgroundTint="@color/overlay_soft"
                    app:cornerRadius="@dimen/radius_pill"
                    app:icon="@drawable/ic_ms_share"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconSize="22dp"
                    app:iconTint="@color/default_white" />
            </LinearLayout>
        </LinearLayout>
    </com.example.travelshare.ui.theme.views.SquareFrameLayout>
</com.google.android.material.card.MaterialCardView>
