<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/warm_white">

<androidx.core.widget.NestedScrollView
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:fillViewport="true"
    android:background="@color/warm_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Hero image -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp">

            <ImageView
                android:id="@+id/iv_detail_hero"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@color/navy_light" />

            <!-- Overlay gradient bas -->
            <View
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_gravity="bottom"
                android:background="#99000000" />

            <!-- Bouton retour -->
            <TextView
                android:id="@+id/btn_back"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_margin="14dp"
                android:gravity="center"
                android:text="←"
                android:textColor="@color/default_white"
                android:textSize="18sp"
                android:background="#55000000"
                android:layout_gravity="top|start" />

            <!-- Lieu pill en bas -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_detail_location"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#55FFFFFF"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="5dp"
                    android:textColor="@color/default_white"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <!-- Corps -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@color/warm_white">

            <!-- Titre -->
            <TextView
                android:id="@+id/tv_detail_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/ink"
                android:textSize="22sp"
                android:fontFamily="serif"
                android:layout_marginBottom="4dp" />

            <!-- Auteur + date -->
            <TextView
                android:id="@+id/tv_detail_author_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/ink_faint"
                android:textSize="11sp"
                android:layout_marginBottom="12dp" />

            <!-- Tags row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <TextView
                    android:id="@+id/tv_detail_category_tags"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pill_outline"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:textColor="@color/teal"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Info blocks : Coord · Période · Accès -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:id="@+id/block_coord"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/sand"
                    android:padding="10dp"
                    android:layout_marginEnd="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="COORD."
                        android:textSize="9sp"
                        android:textColor="@color/ink_faint"
                        android:letterSpacing="0.08" />
                    <TextView
                        android:id="@+id/tv_detail_coord"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/ink"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/sand"
                    android:padding="10dp"
                    android:layout_marginEnd="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PÉRIODE"
                        android:textSize="9sp"
                        android:textColor="@color/ink_faint"
                        android:letterSpacing="0.08" />
                    <TextView
                        android:id="@+id/tv_detail_period"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/ink"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/sand"
                    android:padding="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ACCÈS"
                        android:textSize="9sp"
                        android:textColor="@color/ink_faint"
                        android:letterSpacing="0.08" />
                    <TextView
                        android:id="@+id/tv_detail_access"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/ink"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Likes + Y aller -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp"
                android:layout_marginBottom="16dp">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_detail_like"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="♡ Like"
                    android:textAllCaps="false"
                    android:textColor="@color/terracotta"
                    android:background="#1FC4603A"
                    android:paddingHorizontal="16dp"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:id="@+id/tv_likes_count"
                    android:textColor="@color/ink_muted"
                    android:textSize="12sp"
                    android:layout_marginStart="10dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_detail_route"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Y aller →"
                    android:textAllCaps="false"
                    android:textColor="@color/default_white"
                    android:background="@drawable/bg_pill_solid"
                    android:paddingHorizontal="16dp"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Passerelle TravelPath -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_detail_travelpath"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Planifier un voyage ici — TravelPath"
                android:textAllCaps="false"
                android:textColor="@color/default_white"
                android:background="@color/navy"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- Signaler -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_detail_report"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Signaler ce contenu"
                android:textAllCaps="false"
                android:textColor="@color/ink_faint"
                android:background="@android:color/transparent"
                android:layout_marginBottom="8dp" />

            <!-- Photos similaires -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PHOTOS SIMILAIRES"
                android:textSize="10sp"
                android:textColor="@color/ink_faint"
                android:letterSpacing="0.1"
                android:paddingHorizontal="4dp"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_similar_photos"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp"
                android:clipToPadding="false"
                android:paddingHorizontal="4dp" />

            <!-- Commentaires -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="COMMENTAIRES"
                android:textSize="10sp"
                android:textColor="@color/ink_faint"
                android:letterSpacing="0.1"
                android:paddingHorizontal="4dp"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_comments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="8dp" />

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>

<!-- Barre de commentaire fixe en bas -->
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="8dp"
    android:background="@color/warm_white"
    android:elevation="4dp">

    <EditText
        android:id="@+id/et_comment_input"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="44dp"
        android:hint="Ajouter un commentaire…"
        android:paddingHorizontal="16dp"
        android:background="@color/sand"
        android:textColor="@color/ink"
        android:textSize="13sp"
        android:inputType="text"
        android:layout_marginEnd="8dp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_send_comment"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:text="Envoyer"
        android:textAllCaps="false"
        android:textColor="@color/default_white"
        android:background="@drawable/bg_pill_solid"
        android:paddingHorizontal="14dp"
        android:textSize="12sp" />
</LinearLayout>

</LinearLayout>
