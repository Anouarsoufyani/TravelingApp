<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/space_xl">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="360dp"
                android:background="@color/navy">

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/vp_detail_carousel"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/navy" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="148dp"
                    android:layout_gravity="bottom"
                    android:background="@drawable/bg_photo_overlay_gradient" />

                <ImageButton
                    android:id="@+id/btn_back"
                    android:layout_width="@dimen/touch_target"
                    android:layout_height="@dimen/touch_target"
                    android:layout_gravity="top|start"
                    android:layout_marginStart="@dimen/space_md"
                    android:layout_marginTop="@dimen/space_lg"
                    android:background="@drawable/bg_icon_surface"
                    android:contentDescription="@string/back_content_description"
                    android:padding="@dimen/space_sm"
                    android:src="@drawable/ic_ms_arrow_back" />

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tab_carousel_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="@dimen/space_lg"
                    android:background="@android:color/transparent"
                    app:tabBackground="@drawable/dot_selector"
                    app:tabIndicatorHeight="0dp"
                    app:tabMaxWidth="12dp"
                    app:tabRippleColor="@null" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/space_lg"
                    android:paddingBottom="@dimen/space_xl">

                    <TextView
                        android:id="@+id/tv_detail_location"
                        style="@style/TextAppearance.Travelshare.LabelSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_pill_solid"
                        android:backgroundTint="@color/overlay_soft"
                        android:drawableStart="@drawable/ic_ms_location"
                        android:drawablePadding="@dimen/space_xs"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:paddingHorizontal="@dimen/space_sm"
                        android:paddingVertical="@dimen/space_xxs"
                        android:textColor="@color/default_white" />

                    <TextView
                        android:id="@+id/tv_detail_title"
                        style="@style/TextAppearance.Travelshare.HeadlineLarge"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:textColor="@color/default_white" />
                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_md"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_md">

                    <TextView
                        android:id="@+id/tv_detail_author_initial"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_avatar"
                        android:gravity="center"
                        android:text="@"
                        android:textColor="@color/navy"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_sm"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_detail_author_date"
                            style="@style/TextAppearance.Travelshare.TitleMedium"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="@color/default_white" />

                        <TextView
                            android:id="@+id/tv_detail_category_tags"
                            style="@style/TextAppearance.Travelshare.LabelSmall"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_xxs"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="@color/sheet_muted" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:background="@drawable/bg_card_md"
                    android:orientation="vertical"
                    android:padding="@dimen/space_md">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_likes_count"
                            style="@style/TextAppearance.Travelshare.BodyMedium"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/default_white" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_detail_like"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/touch_target"
                            android:minWidth="96dp"
                            android:text="♡ J’aime"
                            android:textAllCaps="false"
                            android:textColor="@color/coral"
                            app:backgroundTint="@color/coral_soft"
                            app:cornerRadius="@dimen/radius_pill" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/space_xs"
                            android:layout_weight="1"
                            android:background="@drawable/bg_stat_tile"
                            android:orientation="vertical"
                            android:padding="@dimen/space_sm">

                            <TextView
                                style="@style/TextAppearance.Travelshare.LabelSmall"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ACCÈS"
                                android:textColor="@color/sand" />

                            <TextView
                                android:id="@+id/tv_detail_access"
                                style="@style/TextAppearance.Travelshare.LabelSmall"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:textColor="@color/default_white" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_stat_tile"
                            android:orientation="vertical"
                            android:padding="@dimen/space_sm">

                            <TextView
                                style="@style/TextAppearance.Travelshare.LabelSmall"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LIEU"
                                android:textColor="@color/sand" />

                            <TextView
                                style="@style/TextAppearance.Travelshare.LabelSmall"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="@string/route_cta"
                                android:textColor="@color/default_white" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:orientation="vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_detail_travelpath"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:text="@string/travelpath_cta"
                        android:textAllCaps="false"
                        android:textColor="@color/default_white"
                        android:textSize="@dimen/title_medium_size"
                        app:backgroundTint="@color/coral"
                        app:cornerRadius="@dimen/radius_md"
                        app:icon="@drawable/ic_ms_map"
                        app:iconGravity="textStart"
                        app:iconTint="@color/default_white" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_detail_route"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/touch_target"
                            android:layout_marginEnd="@dimen/space_xs"
                            android:layout_weight="1"
                            android:text="@string/route_cta"
                            android:textAllCaps="false"
                            android:textColor="@color/default_white"
                            app:cornerRadius="@dimen/radius_md"
                            app:icon="@drawable/ic_ms_location"
                            app:iconTint="@color/default_white"
                            app:strokeColor="@color/border_light" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_detail_share"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/touch_target"
                            android:layout_weight="1"
                            android:text="@string/share_cta"
                            android:textAllCaps="false"
                            android:textColor="@color/default_white"
                            app:cornerRadius="@dimen/radius_md"
                            app:icon="@drawable/ic_ms_chevron_right"
                            app:iconGravity="textEnd"
                            app:iconTint="@color/default_white"
                            app:strokeColor="@color/border_light" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_voice_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:background="@drawable/bg_card_md"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_md"
                    android:visibility="gone">

                    <TextView
                        style="@style/TextAppearance.Travelshare.TitleMedium"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/voice_note"
                        android:textColor="@color/default_white" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_play_voice"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/touch_target"
                        android:text="@string/play_voice"
                        android:textAllCaps="false"
                        android:textColor="@color/default_white"
                        app:backgroundTint="@color/coral"
                        app:cornerRadius="@dimen/radius_pill" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_owner_actions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_edit_title"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/touch_target"
                        android:layout_marginEnd="@dimen/space_xs"
                        android:layout_weight="1"
                        android:text="@string/edit_title_cta"
                        android:textAllCaps="false"
                        android:textColor="@color/sheet_text"
                        app:cornerRadius="@dimen/radius_md"
                        app:strokeColor="@color/sand" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_delete_post"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/touch_target"
                        android:layout_weight="1"
                        android:text="@string/delete_post_cta"
                        android:textAllCaps="false"
                        android:textColor="@color/coral"
                        app:cornerRadius="@dimen/radius_md"
                        app:strokeColor="@color/coral" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_detail_report"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/touch_target"
                    android:layout_marginTop="@dimen/space_sm"
                    android:text="@string/report_cta"
                    android:textAllCaps="false"
                    android:textColor="@color/sheet_muted" />

                <TextView
                    style="@style/TextAppearance.Travelshare.LabelSmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_lg"
                    android:text="@string/comments"
                    android:textColor="@color/sheet_muted" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_comments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:nestedScrollingEnabled="false" />

                <TextView
                    style="@style/TextAppearance.Travelshare.LabelSmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_lg"
                    android:text="@string/similar_photos"
                    android:textColor="@color/sheet_muted" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_similar_photos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/navy"
        android:elevation="@dimen/bottom_bar_elevation"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/space_sm">

        <EditText
            android:id="@+id/et_comment_input"
            android:layout_width="0dp"
            android:layout_height="@dimen/touch_target"
            android:layout_marginEnd="@dimen/space_xs"
            android:layout_weight="1"
            android:background="@drawable/bg_input"
            android:hint="@string/comment_hint"
            android:inputType="text"
            android:paddingHorizontal="@dimen/space_md"
            android:textColor="@color/default_white"
            android:textColorHint="@color/ink_faint"
            android:textSize="@dimen/body_medium_size" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_send_comment"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/touch_target"
            android:minWidth="88dp"
            android:text="@string/send_comment"
            android:textAllCaps="false"
            android:textColor="@color/default_white"
            app:backgroundTint="@color/coral"
            app:cornerRadius="@dimen/radius_pill" />
    </LinearLayout>
</LinearLayout>
