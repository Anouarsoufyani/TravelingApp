<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/hero_detail_height">

                <ImageView
                    android:id="@+id/iv_detail_hero"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_photo_placeholder"
                    android:contentDescription="@string/photo_content_description"
                    android:scaleType="centerCrop" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/photo_overlay_height"
                    android:layout_gravity="bottom"
                    android:background="@drawable/bg_photo_overlay_gradient" />

                <ImageButton
                    android:id="@+id/btn_back"
                    android:layout_width="@dimen/touch_target"
                    android:layout_height="@dimen/touch_target"
                    android:layout_gravity="top|start"
                    android:layout_marginStart="@dimen/space_md"
                    android:layout_marginTop="@dimen/space_lg"
                    android:background="@drawable/bg_icon_surface"
                    android:contentDescription="@string/back_content_description"
                    android:padding="@dimen/space_sm"
                    android:src="@drawable/ic_ms_arrow_back" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:orientation="vertical"
                    android:padding="@dimen/space_lg">

                    <TextView
                        android:id="@+id/tv_detail_location"
                        style="@style/TextAppearance.Travelshare.LabelSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_pill_outline"
                        android:drawableStart="@drawable/ic_ms_location"
                        android:drawablePadding="@dimen/space_xs"
                        android:paddingStart="@dimen/space_sm"
                        android:paddingTop="@dimen/space_xxs"
                        android:paddingEnd="@dimen/space_sm"
                        android:paddingBottom="@dimen/space_xxs"
                        android:textColor="@color/default_white" />

                    <TextView
                        android:id="@+id/tv_detail_title"
                        style="@style/TextAppearance.Travelshare.HeadlineLarge"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:maxLines="2" />
                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_sheet_top"
                android:orientation="vertical"
                android:padding="@dimen/space_lg">

                <TextView
                    android:id="@+id/tv_detail_author_date"
                    style="@style/TextAppearance.Travelshare.BodyMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/sheet_muted" />

                <TextView
                    android:id="@+id/tv_detail_category_tags"
                    style="@style/TextAppearance.Travelshare.LabelSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:background="@drawable/bg_pill_outline"
                    android:paddingStart="@dimen/space_md"
                    android:paddingTop="@dimen/space_xs"
                    android:paddingEnd="@dimen/space_md"
                    android:paddingBottom="@dimen/space_xs"
                    android:textColor="@color/sheet_text" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_lg"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/block_coord"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/space_xs"
                        android:layout_weight="1"
                        android:background="@drawable/bg_stat_tile"
                        android:orientation="vertical"
                        android:padding="@dimen/space_sm">

                        <TextView
                            style="@style/TextAppearance.Travelshare.LabelSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="COORD."
                            android:textColor="@color/sand" />

                        <TextView
                            android:id="@+id/tv_detail_coord"
                            style="@style/TextAppearance.Travelshare.LabelSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/default_white" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/space_xs"
                        android:layout_weight="1"
                        android:background="@drawable/bg_stat_tile"
                        android:orientation="vertical"
                        android:padding="@dimen/space_sm">

                        <TextView
                            style="@style/TextAppearance.Travelshare.LabelSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PÉRIODE"
                            android:textColor="@color/sand" />

                        <TextView
                            android:id="@+id/tv_detail_period"
                            style="@style/TextAppearance.Travelshare.LabelSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/default_white" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_stat_tile"
                        android:orientation="vertical"
                        android:padding="@dimen/space_sm">

                        <TextView
                            style="@style/TextAppearance.Travelshare.LabelSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ACCÈS"
                            android:textColor="@color/sand" />

                        <TextView
                            android:id="@+id/tv_detail_access"
                            style="@style/TextAppearance.Travelshare.LabelSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/default_white" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_lg"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_detail_like"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/touch_target"
                        android:text="♡ Like"
                        android:textAllCaps="false"
                        android:textColor="@color/coral"
                        app:backgroundTint="@color/coral_soft"
                        app:cornerRadius="@dimen/radius_md" />

                    <TextView
                        android:id="@+id/tv_likes_count"
                        style="@style/TextAppearance.Travelshare.BodyMedium"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_sm"
                        android:layout_weight="1"
                        android:textColor="@color/sheet_muted" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_detail_route"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/touch_target"
                        android:layout_marginEnd="@dimen/space_xs"
                        android:text="@string/route_cta"
                        android:textAllCaps="false"
                        android:textColor="@color/default_white"
                        app:backgroundTint="@color/coral"
                        app:cornerRadius="@dimen/radius_md" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_detail_share"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/touch_target"
                        android:text="@string/share_cta"
                        android:textAllCaps="false"
                        android:textColor="@color/sheet_text"
                        app:cornerRadius="@dimen/radius_md"
                        app:strokeColor="@color/sand" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_share_to_group"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/touch_target"
                    android:layout_marginTop="@dimen/space_md"
                    android:text="@string/share_group"
                    android:textAllCaps="false"
                    android:textColor="@color/sheet_text"
                    app:cornerRadius="@dimen/radius_md"
                    app:strokeColor="@color/sand" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_detail_report"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/touch_target"
                    android:text="@string/report_cta"
                    android:textAllCaps="false"
                    android:textColor="@color/sheet_muted" />

                <LinearLayout
                    android:id="@+id/layout_owner_actions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_edit_title"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/touch_target"
                        android:layout_marginEnd="@dimen/space_xs"
                        android:layout_weight="1"
                        android:text="@string/edit_title_cta"
                        android:textAllCaps="false"
                        android:textColor="@color/sheet_text"
                        app:cornerRadius="@dimen/radius_md"
                        app:strokeColor="@color/sand" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_delete_post"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/touch_target"
                        android:layout_weight="1"
                        android:text="@string/delete_post_cta"
                        android:textAllCaps="false"
                        android:textColor="@color/coral"
                        app:cornerRadius="@dimen/radius_md"
                        app:strokeColor="@color/coral" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_voice_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:background="@drawable/bg_card_md"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_md"
                    android:visibility="gone">

                    <TextView
                        style="@style/TextAppearance.Travelshare.TitleMedium"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/voice_note" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_play_voice"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/touch_target"
                        android:text="@string/play_voice"
                        android:textAllCaps="false"
                        android:textColor="@color/default_white"
                        app:backgroundTint="@color/coral"
                        app:cornerRadius="@dimen/radius_md" />
                </LinearLayout>

                <TextView
                    style="@style/TextAppearance.Travelshare.LabelSmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_lg"
                    android:text="@string/similar_photos"
                    android:textColor="@color/sheet_muted" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_similar_photos"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/similar_strip_height"
                    android:layout_marginTop="@dimen/space_xs"
                    android:clipToPadding="false"
                    android:orientation="horizontal" />

                <TextView
                    style="@style/TextAppearance.Travelshare.LabelSmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_lg"
                    android:text="@string/comments"
                    android:textColor="@color/sheet_muted" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_comments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/navy"
        android:elevation="@dimen/bottom_bar_elevation"
        android:orientation="vertical"
        android:padding="@dimen/space_xs">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_detail_travelpath"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="@string/travelpath_cta"
            android:textAllCaps="false"
            android:textColor="@color/default_white"
            android:textSize="@dimen/title_medium_size"
            app:backgroundTint="@color/coral"
            app:cornerRadius="@dimen/radius_md" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/et_comment_input"
                android:layout_width="0dp"
                android:layout_height="@dimen/touch_target"
                android:layout_marginEnd="@dimen/space_xs"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:hint="@string/comment_hint"
                android:inputType="text"
                android:paddingStart="@dimen/space_md"
                android:paddingEnd="@dimen/space_md"
                android:textColor="@color/default_white"
                android:textColorHint="@color/ink_faint"
                android:textSize="@dimen/body_medium_size" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_send_comment"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/touch_target"
                android:text="@string/send_comment"
                android:textAllCaps="false"
                android:textColor="@color/default_white"
                app:backgroundTint="@color/coral"
                app:cornerRadius="@dimen/radius_md" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
