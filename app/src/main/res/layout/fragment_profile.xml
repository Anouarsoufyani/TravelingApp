<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="96dp">

        <!-- Hero / Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@color/navy"
            android:orientation="vertical"
            android:gravity="bottom"
            android:padding="@dimen/space_xl">

            <FrameLayout
                android:id="@+id/frame_avatar"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginBottom="@dimen/space_md">

                <TextView
                    android:id="@+id/tv_profile_avatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="U"
                    android:textColor="@color/default_white"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_pill_solid"
                    android:backgroundTint="@color/surface_field" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_profile_avatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Travelshare.Pill" />

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="bottom|end"
                    android:gravity="center"
                    android:text="✎"
                    android:textSize="12sp"
                    android:textColor="@color/default_white"
                    android:background="@drawable/bg_pill_solid"
                    android:backgroundTint="@color/coral" />

                <TextView
                    android:id="@+id/btn_delete_avatar"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="top|end"
                    android:background="@drawable/bg_pill_solid"
                    android:backgroundTint="@color/navy"
                    android:clickable="true"
                    android:elevation="2dp"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="×"
                    android:textColor="@color/default_white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </FrameLayout>

            <TextView
                android:id="@+id/tv_profile_name"
                style="@style/TextAppearance.Travelshare.HeadlineLarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Utilisateur"
                android:textColor="@color/default_white" />

            <TextView
                android:id="@+id/tv_profile_handle"
                style="@style/TextAppearance.Travelshare.BodyMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@pseudo"
                android:textColor="@color/sheet_muted" />
        </LinearLayout>

        <!-- Stats Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/space_xl"
            android:paddingVertical="@dimen/space_lg"
            android:background="@color/surface_card">

            <LinearLayout style="@style/StatContainer">
                <TextView android:id="@+id/tv_stat_photos" style="@style/StatValue" android:text="0" />
                <TextView style="@style/StatLabel" android:text="PHOTOS" />
            </LinearLayout>

            <LinearLayout style="@style/StatContainer">
                <TextView android:id="@+id/tv_stat_likes" style="@style/StatValue" android:text="0" />
                <TextView style="@style/StatLabel" android:text="J’AIME" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_stat_groups"
                style="@style/StatContainer"
                android:clickable="true"
                android:foreground="?attr/selectableItemBackground">
                <TextView android:id="@+id/tv_stat_groups" style="@style/StatValue" android:text="0" />
                <TextView style="@style/StatLabel" android:text="GROUPES" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_stat_following"
                style="@style/StatContainer"
                android:clickable="true"
                android:foreground="?attr/selectableItemBackground">
                <TextView android:id="@+id/tv_stat_following" style="@style/StatValue" android:text="0" />
                <TextView style="@style/StatLabel" android:text="SUIVIS" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_stat_followers"
                style="@style/StatContainer"
                android:clickable="true"
                android:foreground="?attr/selectableItemBackground">
                <TextView android:id="@+id/tv_stat_followers" style="@style/StatValue" android:text="0" />
                <TextView style="@style/StatLabel" android:text="ABONNÉS" />
            </LinearLayout>
        </LinearLayout>

        <!-- Bio Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_xl">

            <TextView
                style="@style/StatLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BIO"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/et_bio"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:hint="Parlez-nous de vos voyages..."
                    android:background="@android:color/transparent"
                    android:textColor="@color/default_white"
                    android:textColorHint="@color/ink_faint"
                    android:textSize="14sp"
                    android:maxLines="3" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save_bio"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enregistrer"
                    android:textColor="@color/coral"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Groups Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/space_xl"
                android:layout_marginBottom="@dimen/space_md">

                <TextView
                    style="@style/StatLabel"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="MES GROUPES" />

                <TextView
                    android:id="@+id/btn_groups"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Voir tous →"
                    android:textColor="@color/sand"
                    android:textSize="12sp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_profile_groups"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <!-- Publications / parcours sauvegardés -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="@dimen/space_xl"
                android:background="@drawable/bg_pill_solid"
                android:backgroundTint="@color/surface_card"
                android:orientation="horizontal"
                android:padding="4dp">

                <TextView
                    android:id="@+id/tab_profile_posts"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_pill_solid"
                    android:backgroundTint="@color/coral"
                    android:gravity="center"
                    android:text="Publications"
                    android:textColor="@color/default_white"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tab_profile_paths"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Parcours"
                    android:textColor="@color/sheet_muted"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_profile_content_empty"
                style="@style/TextAppearance.Travelshare.BodyMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingVertical="@dimen/space_xl"
                android:text="Aucune publication pour le moment."
                android:textColor="@color/sheet_muted"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_profile_posts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_profile_paths"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                android:visibility="gone" />

            <!-- Logout -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_logout"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="@dimen/space_xl"
                android:text="Déconnexion"
                android:textAllCaps="false"
                android:textColor="@color/sheet_muted"
                app:cornerRadius="@dimen/radius_md"
                app:strokeColor="@color/border_light" />

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
