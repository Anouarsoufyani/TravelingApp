<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Hero teal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@color/teal"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:padding="16dp">

            <!-- Avatar cliquable -->
            <FrameLayout
                android:id="@+id/frame_avatar"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="12dp">

                <TextView
                    android:id="@+id/tv_profile_avatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="M"
                    android:textColor="@color/ink"
                    android:textSize="22sp"
                    android:fontFamily="serif"
                    android:background="@color/sand" />

                <ImageView
                    android:id="@+id/iv_profile_avatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="16dp"
                    android:layout_gravity="bottom"
                    android:gravity="center"
                    android:text="✎"
                    android:textSize="10sp"
                    android:textColor="@color/default_white"
                    android:background="#88000000" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_profile_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Utilisateur"
                    android:textColor="@color/default_white"
                    android:textSize="17sp"
                    android:fontFamily="serif" />

                <TextView
                    android:id="@+id/tv_profile_handle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@anonyme"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Biographie -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="BIOGRAPHIE"
                android:textSize="10sp"
                android:textColor="@color/ink_faint"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/sand"
                android:padding="10dp"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/et_bio"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:hint="Ajoutez une bio…"
                    android:textColor="@color/ink"
                    android:textSize="13sp"
                    android:background="@android:color/transparent"
                    android:inputType="textMultiLine"
                    android:maxLines="3" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_save_bio"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="OK"
                    android:textAllCaps="false"
                    android:textColor="@color/default_white"
                    android:background="@drawable/bg_pill_solid"
                    android:paddingHorizontal="12dp"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Stats grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@color/sand"
                    android:padding="10dp"
                    android:layout_marginEnd="6dp">
                    <TextView
                        android:id="@+id/tv_stat_photos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:fontFamily="serif"
                        android:textColor="@color/ink" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PHOTOS"
                        android:textSize="9sp"
                        android:textColor="@color/ink_faint"
                        android:letterSpacing="0.08" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@color/sand"
                    android:padding="10dp"
                    android:layout_marginEnd="6dp">
                    <TextView
                        android:id="@+id/tv_stat_likes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:fontFamily="serif"
                        android:textColor="@color/ink" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LIKES"
                        android:textSize="9sp"
                        android:textColor="@color/ink_faint"
                        android:letterSpacing="0.08" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@color/sand"
                    android:padding="10dp">
                    <TextView
                        android:id="@+id/tv_stat_groups"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:fontFamily="serif"
                        android:textColor="@color/ink" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GROUPES"
                        android:textSize="9sp"
                        android:textColor="@color/ink_faint"
                        android:letterSpacing="0.08" />
                </LinearLayout>
            </LinearLayout>

            <!-- Mes publications -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MES PUBLICATIONS"
                android:textSize="10sp"
                android:textColor="@color/ink_faint"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_my_photos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="20dp" />

            <!-- Mes groupes -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="MES GROUPES"
                    android:textSize="10sp"
                    android:textColor="@color/ink_faint"
                    android:letterSpacing="0.1" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_groups"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="+ Voir tous"
                    android:textAllCaps="false"
                    android:textColor="@color/ink"
                    android:background="@drawable/bg_pill_outline"
                    android:textSize="11sp"
                    android:paddingHorizontal="12dp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_profile_groups"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="20dp" />

            <!-- Alertes configurées -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ALERTES CONFIGURÉES"
                android:textSize="10sp"
                android:textColor="@color/ink_faint"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/layout_alerts_preview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/sand"
                android:padding="12dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/tv_alerts_preview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Aucune alerte configurée."
                    android:textColor="@color/ink_muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+ Gérer mes alertes"
                    android:textColor="@color/teal"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Déconnexion -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Se déconnecter"
                android:textColor="@color/ink_faint"
                android:background="@drawable/bg_pill_outline"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:layout_marginBottom="80dp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
