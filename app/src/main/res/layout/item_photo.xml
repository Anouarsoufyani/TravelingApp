<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/photo_card_height"
    android:layout_marginStart="@dimen/space_md"
    android:layout_marginEnd="@dimen/space_md"
    android:layout_marginBottom="@dimen/space_sm"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/navy_light"
    app:cardCornerRadius="@dimen/radius_lg"
    app:cardElevation="@dimen/elevation_card"
    app:cardUseCompatPadding="true"
    app:strokeWidth="@dimen/stroke_none">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <View
            android:id="@+id/photo_gradient_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_photo_placeholder" />

        <ImageView
            android:id="@+id/photo_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/photo_content_description"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/photo_overlay_height"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_photo_overlay_gradient" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_md"
            android:paddingEnd="@dimen/space_md"
            android:paddingBottom="@dimen/space_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/touch_target"
                    android:layout_height="@dimen/touch_target"
                    android:contentDescription="@string/location_icon_description"
                    android:padding="@dimen/space_sm"
                    android:src="@drawable/ic_ms_location" />

                <TextView
                    android:id="@+id/photo_location"
                    style="@style/TextAppearance.Travelshare.HeadlineLarge"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1" />
            </LinearLayout>

            <TextView
                android:id="@+id/photo_title"
                style="@style/TextAppearance.Travelshare.BodyMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="@dimen/avatar_sm"
                    android:layout_height="@dimen/avatar_sm"
                    android:background="@drawable/bg_avatar"
                    android:contentDescription="@string/avatar_content_description"
                    android:gravity="center"
                    android:text="T"
                    android:textColor="@color/navy"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/photo_author"
                    style="@style/TextAppearance.Travelshare.TitleMedium"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_xs"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <ImageView
                    android:layout_width="@dimen/touch_target"
                    android:layout_height="@dimen/touch_target"
                    android:contentDescription="@string/like_icon_description"
                    android:padding="@dimen/space_sm"
                    android:src="@drawable/ic_ms_heart" />

                <TextView
                    android:id="@+id/photo_likes"
                    style="@style/TextAppearance.Travelshare.LabelSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_xxs"
                    android:textColor="@color/default_white" />
            </LinearLayout>

            <TextView
                android:id="@+id/photo_cat_tags"
                style="@style/TextAppearance.Travelshare.LabelSmall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                android:ellipsize="end"
                android:maxLines="1" />
        </LinearLayout>
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>
