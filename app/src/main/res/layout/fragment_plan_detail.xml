<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/space_md">

        <TextView
            android:id="@+id/btn_pd_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:text="←"
            android:textColor="@color/default_white"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/tv_pd_title"
            style="@style/TextAppearance.Travelshare.TitleMedium"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="@dimen/space_sm"
            android:textColor="@color/default_white" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="48dp">

            <!-- Metrics -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/space_xl"
                android:paddingVertical="@dimen/space_lg">

                <LinearLayout style="@style/StatContainer">
                    <TextView style="@style/StatLabel" android:text="BUDGET" />
                    <TextView android:id="@+id/tv_pd_budget" style="@style/StatValue" android:text="0 €" />
                </LinearLayout>

                <LinearLayout style="@style/StatContainer">
                    <TextView style="@style/StatLabel" android:text="DURÉE" />
                    <TextView android:id="@+id/tv_pd_duration" style="@style/StatValue" android:text="0 h" />
                </LinearLayout>

                <LinearLayout style="@style/StatContainer">
                    <TextView style="@style/StatLabel" android:text="EFFORT" />
                    <TextView android:id="@+id/tv_pd_effort" style="@style/StatValue" android:text="-" />
                </LinearLayout>
            </LinearLayout>

            <!-- Weather Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layout_weather"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_xl"
                android:layout_marginBottom="@dimen/space_lg"
                android:visibility="gone"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_md">

                    <TextView
                        android:id="@+id/tv_weather_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="32sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="@dimen/space_md">

                        <TextView
                            android:id="@+id/tv_weather_desc"
                            style="@style/TextAppearance.Travelshare.TitleMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/default_white" />

                        <TextView
                            android:id="@+id/tv_weather_advice"
                            style="@style/TextAppearance.Travelshare.LabelSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/sheet_muted" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_weather_temp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/coral"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Map Area -->
            <TextView
                style="@style/TextAppearance.Travelshare.LabelSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/space_xl"
                android:paddingBottom="@dimen/space_sm"
                android:text="ITINÉRAIRE"
                android:textColor="@color/sheet_muted" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginHorizontal="@dimen/space_xl"
                android:layout_marginBottom="@dimen/space_lg"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_light"
                app:strokeWidth="1dp">

                <org.osmdroid.views.MapView
                    android:id="@+id/map_plan"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Temps de trajet -->
            <LinearLayout
                android:id="@+id/block_route_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_xl"
                android:layout_marginBottom="@dimen/space_sm"
                android:background="@drawable/bg_dark_chip"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/space_md"
                android:paddingVertical="6dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚶 "
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_route_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/default_white"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Steps List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_plan_steps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="@dimen/space_md" />

            <!-- Primary Action: Like/Save -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pd_like"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="@dimen/space_xl"
                android:layout_marginTop="@dimen/space_xl"
                android:text="♡ Sauvegarder ce parcours"
                android:textAllCaps="false"
                android:textColor="@color/navy"
                android:textStyle="bold"
                app:backgroundTint="@color/sand"
                app:cornerRadius="@dimen/radius_md" />

            <!-- Secondary Actions Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_xl"
                android:layout_marginTop="@dimen/space_md"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_pd_share"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="@dimen/space_xs"
                    android:layout_weight="1"
                    android:text="Partager"
                    android:textAllCaps="false"
                    android:textColor="@color/default_white"
                    app:cornerRadius="@dimen/radius_md"
                    app:strokeColor="@color/border_light" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_pd_export_pdf"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="PDF"
                    android:textAllCaps="false"
                    android:textColor="@color/default_white"
                    app:cornerRadius="@dimen/radius_md"
                    app:strokeColor="@color/border_light" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pd_regenerate"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_xl"
                android:layout_marginTop="@dimen/space_md"
                android:text="Modifier et regénérer"
                android:textAllCaps="false"
                android:textColor="@color/sheet_muted" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
