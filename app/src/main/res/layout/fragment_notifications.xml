<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_color">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/space_xl"
        android:paddingTop="@dimen/space_xl"
        android:paddingEnd="@dimen/space_xl"
        android:paddingBottom="@dimen/space_md">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                style="@style/TextAppearance.Travelshare.HeadlineLarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notifications"
                android:textColor="@color/default_white"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                style="@style/TextAppearance.Travelshare.BodyMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Restez au courant de vos voyages"
                android:textColor="@color/sheet_muted" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_clear_notifs"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tout effacer"
            android:textAllCaps="false"
            android:textColor="@color/coral"
            android:textSize="12sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_light"
        android:layout_marginHorizontal="@dimen/space_xl" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_notifications_feed"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="@dimen/space_md"
        android:paddingBottom="80dp" />

</LinearLayout>
