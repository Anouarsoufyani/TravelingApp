<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_color">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/navy">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="🗺 TravelPath"
            android:textColor="@color/default_white"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Onglets Générés / Sauvegardés -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="@color/navy_light">

        <TextView
            android:id="@+id/tab_tp_all"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="Mes parcours"
            android:textColor="@color/default_white"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@color/teal" />

        <TextView
            android:id="@+id/tv_tp_saved_tab"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="❤️ Sauvegardés"
            android:textColor="#AACCFF"
            android:textSize="13sp"
            android:background="@android:color/transparent" />
    </LinearLayout>

    <!-- Bannière mode hors-ligne -->
    <TextView
        android:id="@+id/tv_tp_offline_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📴 Hors-ligne — génération indisponible. Plans sauvegardés accessibles."
        android:textColor="@color/default_white"
        android:textSize="12sp"
        android:gravity="center"
        android:padding="8dp"
        android:background="@color/terracotta"
        android:visibility="gone" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="80dp">

            <!-- Formulaire de préférences -->
            <LinearLayout
                android:id="@+id/layout_tp_form"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/default_white"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PLANIFIER MON VOYAGE"
                    android:textSize="10sp"
                    android:textColor="@color/ink_faint"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="12dp" />

                <!-- Ville -->
                <EditText
                    android:id="@+id/et_tp_city"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Ville ou destination"
                    android:paddingHorizontal="14dp"
                    android:background="@drawable/bg_input"
                    android:textColor="@color/ink"
                    android:textSize="14sp"
                    android:inputType="text"
                    android:layout_marginBottom="14dp" />

                <!-- Activités -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Activités souhaitées"
                    android:textSize="12sp"
                    android:textColor="@color/ink_muted"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">

                    <CheckBox android:id="@+id/cb_culture"
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Culture" android:textSize="13sp" android:checked="true"/>
                    <CheckBox android:id="@+id/cb_restauration"
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Resto" android:textSize="13sp" android:checked="true"/>
                    <CheckBox android:id="@+id/cb_loisirs"
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Loisirs" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <CheckBox android:id="@+id/cb_decouverte"
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Découverte" android:textSize="13sp" android:checked="true"/>
                    <CheckBox android:id="@+id/cb_shopping"
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Shopping" android:textSize="13sp"/>
                    <View android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- Lieux obligatoires -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lieux à inclure (optionnel, séparés par virgule)"
                    android:textSize="12sp"
                    android:textColor="@color/ink_muted"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/et_tp_required_places"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:hint="Ex: Tour Eiffel, Louvre"
                    android:paddingHorizontal="12dp"
                    android:background="@drawable/bg_input"
                    android:textColor="@color/ink"
                    android:textSize="13sp"
                    android:inputType="text"
                    android:layout_marginBottom="14dp" />

                <!-- Tolérances météo -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sensibilités météo"
                    android:textSize="12sp"
                    android:textColor="@color/ink_muted"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">
                    <CheckBox android:id="@+id/cb_cold"
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="❄️ Froid" android:textSize="12sp"/>
                    <CheckBox android:id="@+id/cb_heat"
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="☀️ Chaleur" android:textSize="12sp"/>
                    <CheckBox android:id="@+id/cb_humidity"
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="💧 Humidité" android:textSize="12sp"/>
                </LinearLayout>

                <!-- Budget -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Budget maximum" android:textSize="12sp" android:textColor="@color/ink_muted"/>
                    <TextView android:id="@+id/tv_tp_budget_value"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="100 €" android:textSize="13sp" android:textColor="@color/teal"
                        android:textStyle="bold"/>
                </LinearLayout>
                <SeekBar
                    android:id="@+id/seekbar_tp_budget"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="500"
                    android:progress="100"
                    android:layout_marginBottom="14dp" />

                <!-- Durée -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Durée de la visite" android:textSize="12sp" android:textColor="@color/ink_muted"/>
                    <TextView android:id="@+id/tv_tp_duration_value"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="4 h" android:textSize="13sp" android:textColor="@color/teal"
                        android:textStyle="bold"/>
                </LinearLayout>
                <SeekBar
                    android:id="@+id/seekbar_tp_duration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="10"
                    android:progress="3"
                    android:layout_marginBottom="14dp" />

                <!-- Effort -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Niveau d'effort"
                    android:textSize="12sp"
                    android:textColor="@color/ink_muted"
                    android:layout_marginBottom="6dp" />

                <RadioGroup
                    android:id="@+id/rg_tp_effort"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">
                    <RadioButton android:id="@+id/rb_facile"
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Facile" android:textSize="13sp" android:checked="true"/>
                    <RadioButton android:id="@+id/rb_modere"
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Modéré" android:textSize="13sp"/>
                    <RadioButton android:id="@+id/rb_intense"
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Intense" android:textSize="13sp"/>
                </RadioGroup>

                <!-- Générer -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_tp_generate"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Générer mes parcours"
                    android:textAllCaps="false"
                    android:textColor="@color/default_white"
                    android:background="@drawable/bg_pill_solid"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Bouton tout supprimer — visible seulement si des parcours existent -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_tp_delete_all"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="🗑 Supprimer tous les parcours"
                android:textAllCaps="false"
                android:textColor="@color/terracotta"
                android:background="@android:color/transparent"
                android:textSize="13sp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

            <!-- Résultats -->
            <TextView
                android:id="@+id/tv_tp_results_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PARCOURS GÉNÉRÉS"
                android:textSize="10sp"
                android:textColor="@color/ink_faint"
                android:letterSpacing="0.1"
                android:paddingHorizontal="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_tp_plans"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
