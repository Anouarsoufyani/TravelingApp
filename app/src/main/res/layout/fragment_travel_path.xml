<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_xl"
            android:paddingTop="@dimen/space_xl"
            android:paddingEnd="@dimen/space_xl"
            android:paddingBottom="@dimen/space_md">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TravelPath"
                android:textColor="@color/default_white"
                android:textSize="32sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Générez votre parcours personnalisé"
                android:textColor="@color/sheet_muted"
                android:textSize="14sp" />
        </LinearLayout>

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabs_tp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:tabIndicatorColor="@color/coral"
            app:tabIndicatorHeight="3dp"
            app:tabSelectedTextColor="@color/default_white"
            app:tabTextColor="@color/ink_faint"
            app:tabTextAppearance="@style/TextAppearance.Travelshare.LabelSmall"
            app:tabRippleColor="@color/coral_soft">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Formulaire" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sauvegardés" />
        </com.google.android.material.tabs.TabLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- ONGLET 0 : Formulaire + Résultats en dessous -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll_tp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="96dp">

                <!-- Formulaire -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/space_xl"
                    android:layout_marginTop="@dimen/space_md"
                    android:layout_marginBottom="@dimen/space_md"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="@dimen/radius_lg"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border_light"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_xl">

                        <TextView style="@style/StatLabel" android:text="DESTINATION" android:layout_marginBottom="8dp" />
                        <EditText
                            android:id="@+id/et_tp_city"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:hint="Ville ou pays"
                            android:background="@drawable/bg_input"
                            android:paddingHorizontal="@dimen/space_md"
                            android:textColor="@color/default_white"
                            android:textColorHint="@color/ink_faint"
                            android:inputType="textCapWords"
                            android:layout_marginBottom="16dp" />

                        <TextView style="@style/StatLabel" android:text="ENDROITS SPÉCIFIQUES (optionnel)" android:layout_marginBottom="8dp" />
                        <EditText
                            android:id="@+id/et_tp_required_places"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:hint="Ex: Tour Eiffel, Louvre..."
                            android:background="@drawable/bg_input"
                            android:paddingHorizontal="@dimen/space_md"
                            android:textColor="@color/default_white"
                            android:textColorHint="@color/ink_faint"
                            android:inputType="textCapSentences"
                            android:layout_marginBottom="12dp" />

                        <RadioGroup
                            android:id="@+id/rg_places_mode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginBottom="20dp">
                            <RadioButton android:id="@+id/rb_places_plus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ces lieux + nouvelles suggestions selon mes critères" android:textColor="@color/default_white" android:textSize="13sp" android:buttonTint="@color/coral" android:checked="true" />
                            <RadioButton android:id="@+id/rb_places_only" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ces lieux uniquement" android:textColor="@color/default_white" android:textSize="13sp" android:buttonTint="@color/coral" />
                        </RadioGroup>

                        <TextView style="@style/StatLabel" android:text="ACTIVITÉS" android:layout_marginBottom="12dp" />
                        <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:columnCount="2" android:layout_marginBottom="24dp">
                            <CheckBox android:id="@+id/cb_culture"      android:text="🏛 Culture"      android:textColor="@color/default_white" android:buttonTint="@color/coral" />
                            <CheckBox android:id="@+id/cb_restauration" android:text="🍽 Restauration" android:textColor="@color/default_white" android:buttonTint="@color/coral" android:checked="true" />
                            <CheckBox android:id="@+id/cb_loisirs"      android:text="🎭 Loisirs"      android:textColor="@color/default_white" android:buttonTint="@color/coral" />
                            <CheckBox android:id="@+id/cb_decouverte"   android:text="🌍 Découverte"   android:textColor="@color/default_white" android:buttonTint="@color/coral" android:checked="true" />
                            <CheckBox android:id="@+id/cb_shopping"     android:text="🛍 Shopping"     android:textColor="@color/default_white" android:buttonTint="@color/coral" />
                        </GridLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                            <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Budget maximum" android:textColor="@color/sheet_muted" android:textSize="13sp" />
                            <TextView android:id="@+id/tv_tp_budget_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="100 €" android:textColor="@color/sand" android:textStyle="bold" />
                        </LinearLayout>
                        <SeekBar android:id="@+id/seekbar_tp_budget" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="1000" android:progress="100" android:progressTint="@color/coral" android:thumbTint="@color/coral" android:layout_marginBottom="16dp" />

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                            <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Durée de la visite" android:textColor="@color/sheet_muted" android:textSize="13sp" />
                            <TextView android:id="@+id/tv_tp_duration_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4 h" android:textColor="@color/sand" android:textStyle="bold" />
                        </LinearLayout>
                        <SeekBar android:id="@+id/seekbar_tp_duration" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="12" android:progress="3" android:progressTint="@color/coral" android:thumbTint="@color/coral" android:layout_marginBottom="24dp" />

                        <TextView style="@style/StatLabel" android:text="NIVEAU D'EFFORT" android:layout_marginBottom="8dp" />
                        <RadioGroup android:id="@+id/rg_tp_effort" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="24dp">
                            <RadioButton android:id="@+id/rb_facile"  android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Facile"  android:textColor="@color/default_white" android:buttonTint="@color/coral" android:checked="true" />
                            <RadioButton android:id="@+id/rb_modere"  android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Modéré"  android:textColor="@color/default_white" android:buttonTint="@color/coral" />
                            <RadioButton android:id="@+id/rb_intense" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Intense" android:textColor="@color/default_white" android:buttonTint="@color/coral" />
                        </RadioGroup>

                        <FrameLayout android:layout_width="match_parent" android:layout_height="64dp">
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_tp_generate"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="✦ Générer mes parcours"
                                android:textAllCaps="false"
                                android:textColor="@color/default_white"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                app:backgroundTint="@color/coral"
                                app:cornerRadius="@dimen/radius_lg" />
                            <ProgressBar
                                android:id="@+id/progress_tp_generate"
                                style="?android:attr/progressBarStyleSmall"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="start|center_vertical"
                                android:layout_marginStart="28dp"
                                android:indeterminate="true"
                                android:indeterminateTint="@color/default_white"
                                android:visibility="gone" />
                        </FrameLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Résultats (en dessous du formulaire, même onglet) -->
                <LinearLayout
                    android:id="@+id/section_tp_results"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="@dimen/space_xl"
                        android:paddingTop="@dimen/space_sm"
                        android:paddingBottom="@dimen/space_xs">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="MES PARCOURS GÉNÉRÉS"
                            android:textColor="@color/default_white"
                            android:textSize="12sp"
                            android:letterSpacing="0.08"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_tp_delete_all"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🗑 Effacer"
                            android:textColor="@color/coral"
                            android:textAllCaps="false"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_tp_results"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:clipToPadding="false"
                        android:padding="@dimen/space_xs" />
                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- ONGLET 1 : Sauvegardés -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_tp_saved"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="@dimen/space_md"
            android:visibility="gone" />

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
