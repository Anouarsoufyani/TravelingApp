<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/space_md"
    android:layout_marginEnd="@dimen/space_md"
    android:layout_marginBottom="@dimen/space_sm"
    app:cardBackgroundColor="@color/surface_card"
    app:cardCornerRadius="@dimen/radius_lg"
    app:cardElevation="@dimen/elevation_card"
    app:cardUseCompatPadding="true"
    app:strokeColor="@color/border_light"
    app:strokeWidth="@dimen/stroke_hairline">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <View
            android:id="@+id/v_plan_color"
            android:layout_width="@dimen/accent_bar_width"
            android:layout_height="match_parent"
            android:background="@color/coral" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="@dimen/space_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_plan_type_badge"
                    style="@style/TextAppearance.Travelshare.LabelSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pill_solid"
                    android:paddingStart="@dimen/space_sm"
                    android:paddingTop="@dimen/space_xxs"
                    android:paddingEnd="@dimen/space_sm"
                    android:paddingBottom="@dimen/space_xxs"
                    android:textColor="@color/default_white" />

                <TextView
                    android:id="@+id/tv_plan_liked"
                    android:layout_width="@dimen/touch_target"
                    android:layout_height="@dimen/touch_target"
                    android:layout_marginStart="@dimen/space_xs"
                    android:gravity="center"
                    android:text="♡"
                    android:textColor="@color/coral"
                    android:textSize="@dimen/like_text_size" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_plan_city"
                style="@style/TextAppearance.Travelshare.TitleMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/tv_plan_activities"
                style="@style/TextAppearance.Travelshare.BodyMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xxs"
                android:ellipsize="end"
                android:maxLines="1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/touch_target"
                    android:layout_height="@dimen/touch_target"
                    android:contentDescription="@string/route_thumbnail_description"
                    android:padding="@dimen/space_sm"
                    android:src="@drawable/ic_ms_clock" />

                <TextView
                    android:id="@+id/tv_plan_duration"
                    style="@style/TextAppearance.Travelshare.LabelSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/default_white" />

                <ImageView
                    android:layout_width="@dimen/touch_target"
                    android:layout_height="@dimen/touch_target"
                    android:contentDescription="@string/route_thumbnail_description"
                    android:padding="@dimen/space_sm"
                    android:src="@drawable/ic_ms_wallet" />

                <TextView
                    android:id="@+id/tv_plan_budget"
                    style="@style/TextAppearance.Travelshare.LabelSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/default_white" />

                <ImageView
                    android:layout_width="@dimen/touch_target"
                    android:layout_height="@dimen/touch_target"
                    android:contentDescription="@string/route_thumbnail_description"
                    android:padding="@dimen/space_sm"
                    android:src="@drawable/ic_ms_footprint" />

                <TextView
                    android:id="@+id/tv_plan_effort"
                    style="@style/TextAppearance.Travelshare.LabelSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/default_white" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_plan_detail"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/touch_target"
                    android:layout_marginEnd="@dimen/space_xs"
                    android:layout_weight="1"
                    android:text="Voir le parcours"
                    android:textAllCaps="false"
                    android:textColor="@color/default_white"
                    app:backgroundTint="@color/coral"
                    app:cornerRadius="@dimen/radius_md"
                    app:icon="@drawable/ic_ms_chevron_right"
                    app:iconGravity="textEnd"
                    app:iconTint="@color/default_white" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_plan_delete"
                    android:layout_width="@dimen/touch_target"
                    android:layout_height="@dimen/touch_target"
                    android:contentDescription="@string/delete_post_cta"
                    android:text="×"
                    android:textColor="@color/coral"
                    android:textSize="@dimen/delete_text_size"
                    app:backgroundTint="@color/navy_field"
                    app:cornerRadius="@dimen/radius_md" />
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:layout_width="@dimen/route_thumb_size"
            android:layout_height="@dimen/route_thumb_size"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="@dimen/space_md"
            android:background="@drawable/bg_map_thumb">

            <ImageView
                android:layout_width="@dimen/touch_target"
                android:layout_height="@dimen/touch_target"
                android:layout_gravity="center"
                android:contentDescription="@string/route_thumbnail_description"
                android:padding="@dimen/space_sm"
                android:src="@drawable/ic_ms_map" />
        </FrameLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
