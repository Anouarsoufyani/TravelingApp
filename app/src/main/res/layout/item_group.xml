<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/default_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <!-- Avatar du groupe (initiale) -->
        <TextView
            android:id="@+id/tv_group_avatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:textSize="20sp"
            android:textColor="@color/default_white"
            android:fontFamily="serif"
            android:background="@color/teal"
            android:layout_marginEnd="12dp" />

        <!-- Infos -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_group_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ink"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tv_group_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ink_muted"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Badge "N demandes" visible uniquement pour le créateur -->
            <TextView
                android:id="@+id/tv_pending_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/terracotta"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Actions -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <!-- Bouton action principal (Demander / En attente / Membre / Admin) -->
            <TextView
                android:id="@+id/tv_group_action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:textSize="12sp"
                android:background="@drawable/bg_pill_outline"
                android:layout_marginBottom="6dp" />

            <!-- Bouton Discussion (visible seulement dans Mes groupes) -->
            <TextView
                android:id="@+id/tv_group_chat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💬 Discussion"
                android:textColor="@color/teal"
                android:textSize="12sp"
                android:background="@drawable/bg_pill_outline"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:visibility="gone" />

        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>
