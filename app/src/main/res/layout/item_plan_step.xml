<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="4dp"
    android:background="@color/default_white">

    <!-- Timeline dot + line -->
    <LinearLayout
        android:layout_width="32dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginEnd="12dp">

        <TextView
            android:id="@+id/tv_step_icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:textSize="16sp"
            android:background="@color/sand" />

        <View
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:background="@color/sand"
            android:layout_gravity="center_horizontal"
            android:minHeight="16dp"/>
    </LinearLayout>

    <!-- Contenu -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="2dp">

            <TextView
                android:id="@+id/tv_step_slot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/navy_light"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textColor="@color/default_white"
                android:textSize="10sp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tv_step_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ink_faint"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_step_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/ink"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/tv_step_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/ink_faint"
            android:textSize="11sp"
            android:drawableStart="@android:drawable/ic_menu_mylocation"
            android:drawablePadding="4dp"
            android:layout_marginBottom="2dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tv_step_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/ink_muted"
            android:textSize="12sp"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/tv_step_opening_hours"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/gold"
            android:textSize="11sp"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_step_cost"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textColor="@color/teal"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_step_see_photos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📸 Voir photos"
                android:textColor="@color/ink_muted"
                android:textSize="11sp"
                android:padding="4dp"/>

            <TextView
                android:id="@+id/tv_step_video"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▶ Vidéo"
                android:textColor="@color/terracotta"
                android:textSize="11sp"
                android:padding="4dp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Mini-galerie photos TravelShare liées à cette étape -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_step_photos"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:orientation="horizontal"
            android:visibility="gone"
            android:clipToPadding="false"
            android:layout_marginTop="6dp" />

    </LinearLayout>
</LinearLayout>
