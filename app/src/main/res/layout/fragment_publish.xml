<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="96dp">

        <!-- Edge-to-Edge Photo Picker -->
        <FrameLayout
            android:id="@+id/layout_photo_picker"
            android:layout_width="match_parent"
            android:layout_height="400dp"
            android:background="@color/navy">

            <ImageView
                android:id="@+id/iv_photo_preview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#20000000" />

            <LinearLayout
                android:id="@+id/layout_photo_placeholder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="@drawable/bg_photo_overlay_gradient"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/space_xl">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginBottom="@dimen/space_sm"
                    android:src="@drawable/ic_ms_explore"
                    app:tint="@color/default_white" />

                <TextView
                    style="@style/TextAppearance.Travelshare.TitleMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ajouter une photo"
                    android:textColor="@color/default_white" />

                <TextView
                    style="@style/TextAppearance.Travelshare.LabelSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Touchez pour choisir"
                    android:textColor="@color/sand" />
            </LinearLayout>
        </FrameLayout>

        <!-- Form Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-24dp"
            android:background="@drawable/bg_sheet_top"
            android:orientation="vertical"
            android:padding="@dimen/space_xl">

            <TextView
                style="@style/TextAppearance.Travelshare.HeadlineLarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Nouveau Post" />

            <TextView
                style="@style/TextAppearance.Travelshare.BodyMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_lg"
                android:text="Partagez votre découverte."
                android:textColor="@color/sheet_muted" />

            <!-- Title -->
            <EditText
                android:id="@+id/et_pub_title"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="@dimen/space_md"
                android:background="@drawable/bg_input"
                android:hint="Titre du souvenir"
                android:inputType="textCapSentences"
                android:paddingHorizontal="@dimen/space_md"
                android:textColor="@color/default_white"
                android:textColorHint="@color/ink_faint"
                android:textSize="16sp" />

            <!-- Location -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_md"
                android:background="@drawable/bg_input"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingEnd="@dimen/space_md">

                <EditText
                    android:id="@+id/et_pub_location"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Lieu (Ville, Pays)"
                    android:inputType="textCapWords"
                    android:paddingHorizontal="@dimen/space_md"
                    android:textColor="@color/default_white"
                    android:textColorHint="@color/ink_faint"
                    android:textSize="16sp" />

                <CheckBox
                    android:id="@+id/check_approx_location"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/coral"
                    android:text="Approx."
                    android:textColor="@color/sheet_muted"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Category & Tags -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_lg"
                android:orientation="horizontal">

                <Spinner
                    android:id="@+id/spinner_pub_category"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="@dimen/space_xs"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input"
                    android:paddingHorizontal="@dimen/space_sm" />

                <EditText
                    android:id="@+id/et_pub_tags"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1.5"
                    android:background="@drawable/bg_input"
                    android:hint="Tags (#voyage...)"
                    android:inputType="text"
                    android:paddingHorizontal="@dimen/space_md"
                    android:textColor="@color/default_white"
                    android:textColorHint="@color/ink_faint"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Smart Actions (Voice & AI) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_xl"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_record_voice"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="@dimen/space_xs"
                    android:layout_weight="1"
                    android:text="Note Vocale"
                    android:textAllCaps="false"
                    android:textColor="@color/default_white"
                    app:cornerRadius="@dimen/radius_md"
                    app:icon="@drawable/ic_ms_explore"
                    app:iconTint="@color/coral"
                    app:strokeColor="@color/border_light" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_auto_tags"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Auto-tags AI"
                    android:textAllCaps="false"
                    android:textColor="@color/navy"
                    app:backgroundTint="@color/sand"
                    app:cornerRadius="@dimen/radius_md"
                    app:icon="@drawable/ic_ms_explore"
                    app:iconTint="@color/navy" />
            </LinearLayout>

            <!-- Visibility Settings -->
            <TextView
                style="@style/TextAppearance.Travelshare.LabelSmall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_xs"
                android:text="Visibilité"
                android:textColor="@color/sheet_muted" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_visibility"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_md"
                android:text="Restreindre à un groupe privé"
                android:textColor="@color/default_white" />

            <LinearLayout
                android:id="@+id/layout_group_selector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_xl"
                android:orientation="horizontal"
                android:visibility="gone">

                <Spinner
                    android:id="@+id/spinner_groups"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="@dimen/space_xs"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input"
                    android:paddingHorizontal="@dimen/space_sm" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_new_group"
                    android:layout_width="wrap_content"
                    android:layout_height="56dp"
                    android:text="+ Groupe"
                    android:textAllCaps="false"
                    android:textColor="@color/default_white"
                    app:backgroundTint="@color/surface_card"
                    app:cornerRadius="@dimen/radius_md"
                    app:strokeColor="@color/border_light"
                    app:strokeWidth="1dp" />
            </LinearLayout>

            <!-- Publish Action -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_publish_photo"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Publier le souvenir"
                android:textAllCaps="false"
                android:textColor="@color/default_white"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="@color/coral"
                app:cornerRadius="@dimen/radius_lg" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>