<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="14dp"
    android:background="@drawable/bg_card_md"
    android:layout_marginVertical="5dp">

    <!-- Avatar initiales -->
    <TextView
        android:id="@+id/tv_notif_avatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:gravity="center"
        android:textColor="@color/default_white"
        android:textSize="13sp"
        android:textStyle="bold"
        android:background="@drawable/bg_pill_solid"
        android:layout_marginEnd="10dp" />

    <!-- Texte -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_pref_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/ink"
            android:textSize="12sp"
            android:lineSpacingMultiplier="1.3" />

        <TextView
            android:id="@+id/tv_notif_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/ink_faint"
            android:textSize="10sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Bouton supprimer -->
    <Button
        android:id="@+id/btn_pref_delete"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="✕"
        android:textColor="@color/terracotta"
        android:background="@android:color/transparent"
        android:padding="8dp" />

</LinearLayout>
