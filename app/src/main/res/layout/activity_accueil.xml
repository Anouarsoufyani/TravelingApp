<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/background_color"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TravelShare"
        android:fontFamily="serif"
        android:textColor="@color/navy"
        android:textSize="42sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="L'inspiration commence ici."
        android:fontFamily="sans-serif"
        android:textColor="@color/ink_muted"
        android:textSize="16sp"
        android:layout_marginBottom="48dp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_accueil_inscription"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Créer un compte"
        android:textColor="@color/default_white"
        android:background="@drawable/bg_pill_solid"
        android:fontFamily="sans-serif"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:layout_marginBottom="16dp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_accueil_connexion"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Se connecter"
        android:textColor="@color/ink"
        android:background="@drawable/bg_pill_outline"
        android:fontFamily="sans-serif"
        android:textAllCaps="false"
        android:textSize="16sp" />

</LinearLayout>